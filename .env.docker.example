# Docker production-like environment example.
# Copy to .env.docker and replace every placeholder before deployment.

SECRET_KEY=replace-with-a-random-50-plus-character-production-secret
DEBUG=False
ALLOWED_HOSTS=your-domain.com,www.your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Reverse proxy / HTTPS
SECURE_PROXY_SSL_HEADER_NAME=HTTP_X_FORWARDED_PROTO
SECURE_PROXY_SSL_HEADER_VALUE=https
SECURE_SSL_REDIRECT=True
SECURE_HSTS_PRELOAD=True

# Database values are kept here for compose compatibility.
# Do not change database architecture as part of the app hardening pass.
DATABASE_URL=postgres://akshaya_vistara_user:your_strong_password@db:5432/akshaya_vistara_db
POSTGRES_DB=akshaya_vistara_db
POSTGRES_USER=akshaya_vistara_user
POSTGRES_PASSWORD=your_strong_password
RUN_MIGRATIONS=false

# Persistent paths inside the container.
STATIC_ROOT=/app/staticfiles
MEDIA_ROOT=/app/media

# Redis / Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=False
CACHE_URL=redis://redis:6379/1

# Upload limits
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760
DATA_UPLOAD_MAX_MEMORY_SIZE=26214400
DATA_UPLOAD_MAX_NUMBER_FIELDS=5000

# OCR binaries are installed in the Docker image.
TESSERACT_PATH=
POPPLER_PATH=

# Email / SMTP
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.your-provider.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-smtp-user
EMAIL_HOST_PASSWORD=your-smtp-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=Akshaya Vistara <no-reply@your-domain.com>
SERVER_EMAIL=Akshaya Vistara <server@your-domain.com>

# Optional WhatsApp webhook. Use a random 32+ character token if enabled.
WHATSAPP_WEBHOOK_TOKEN=replace-with-random-32-plus-character-token
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

ALLOW_PUBLIC_REGISTRATION=False
REGISTRATION_INVITE_CODE=
REQUIRE_STAFF_MFA=True

GST_API_PROVIDER=
GST_API_BASE_URL=
GST_API_KEY=
GST_API_SECRET=
GST_API_AUTH_PATH=/auth
GST_API_GSTIN_LOOKUP_PATH=/gstin
GST_API_E_INVOICE_PATH=/e-invoice
GST_API_E_WAY_BILL_PATH=/e-way-bill
GST_API_TIMEOUT_SECONDS=20
GST_API_TAXPAYER_GSTIN=
GST_API_USERNAME=
GST_API_PASSWORD=
GST_API_SANDBOX_MODE=True
E_INVOICE_ENABLED=False
E_WAY_BILL_ENABLED=False
BANK_FEED_PROVIDER=
BANK_FEED_BASE_URL=
BANK_FEED_API_KEY=
BANK_FEED_API_SECRET=
PAYMENT_PROVIDER=
PAYMENT_API_KEY=
PAYMENT_WEBHOOK_SECRET=

# Runtime checks
RUN_DEPLOY_CHECKS=true
RUN_COLLECTSTATIC=true
LOG_LEVEL=INFO
