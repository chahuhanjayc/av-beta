# Development environment example.
# Copy to .env for local development and replace placeholder values.

SECRET_KEY=change-this-local-development-secret-key-at-least-50-chars
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Database is intentionally left as local SQLite for development.
DATABASE_URL=sqlite:///db.sqlite3

# Upload limits
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760
DATA_UPLOAD_MAX_MEMORY_SIZE=26214400
DATA_UPLOAD_MAX_NUMBER_FIELDS=5000

# Celery / Redis. Set CELERY_TASK_ALWAYS_EAGER=True if Redis is not running locally.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=True

# OCR binaries for Windows local development.
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
POPPLER_PATH=C:\poppler\Library\bin

# Email uses console backend in DEBUG unless overridden.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=Akshaya Vistara <no-reply@example.com>

# Optional WhatsApp webhook. Use a random 32+ character token if enabled.
WHATSAPP_WEBHOOK_TOKEN=
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# Account security
ALLOW_PUBLIC_REGISTRATION=False
REGISTRATION_INVITE_CODE=
REQUIRE_STAFF_MFA=False

# Production backup trust controls. Use either a generated Fernet key or a
# strong passphrase kept outside source control.
BACKUP_ENCRYPTION_KEY=
BACKUP_ENCRYPTION_PASSPHRASE=
BACKUP_ENCRYPTION_REQUIRED=True
BACKUP_ENCRYPTION_DEFAULT=False
BACKUP_RETENTION_COUNT=10
BACKUP_MAX_AGE_HOURS=24
BACKUP_MIN_RETAINED_MANIFESTS=3
RESTORE_DRILL_MAX_AGE_DAYS=30
BACKUP_SCHEDULE_ENABLED=False
BACKUP_SCHEDULE_INTERVAL_HOURS=24
BACKUP_SCHEDULE_MAX_AGE_HOURS=26
BACKUP_OFFSITE_DIR=
BACKUP_OFFSITE_REQUIRED=True

# External integrations are disabled locally unless explicitly configured.
GST_API_PROVIDER=
GST_API_BASE_URL=
GST_API_KEY=
GST_API_SECRET=
GST_API_AUTH_PATH=/auth
GST_API_GSTIN_LOOKUP_PATH=/gstin
GST_API_E_INVOICE_PATH=/e-invoice
GST_API_E_WAY_BILL_PATH=/e-way-bill
GST_API_TIMEOUT_SECONDS=20
GST_API_TAXPAYER_GSTIN=
GST_API_USERNAME=
GST_API_PASSWORD=
GST_API_SANDBOX_MODE=True
E_INVOICE_ENABLED=False
E_WAY_BILL_ENABLED=False
BANK_FEED_PROVIDER=
BANK_FEED_BASE_URL=
BANK_FEED_API_KEY=
BANK_FEED_API_SECRET=
PAYMENT_PROVIDER=
PAYMENT_API_KEY=
PAYMENT_WEBHOOK_SECRET=
